# Virtual environments
venv/
venv312/

# Python cache
__pycache__/
*.pyc
*.pyo

# Claude Code / AI prompt files
.claude/
cc_instructions_*.md

# Large data files (not suitable for GitHub)
data/

# Research paper PDF (copyrighted)
*.pdf
# ...but generated poster/paper figures are project artifacts, not sources.
# Must stay after *.pdf: git applies the last matching pattern.
!figures/*.pdf

# Generated results (regenerable by running the scripts)
results/

# Log files
*.log
*.txt
!requirements.txt
!requirements.lock.txt

# WIRE-specific path overrides (machine-local; see .env.example)
.env.wire

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# CC instruction files
# Exclude the directory's *contents*, not the directory itself: git does not
# descend into an excluded directory, so a negation under `docs/` would be
# silently inert (gitignore(5)). This shape lets the .md negation take effect.
docs/*
!docs/*.md
CLAUDE.md
PHASE_V_INSTRUCTIONS.md