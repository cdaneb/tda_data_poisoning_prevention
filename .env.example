# Path overrides for paths.py. Copy to .env.wire (or export directly) and
# fill in real values for your machine; unset variables fall back to
# repo-relative defaults (data/, results/, models/, figures/).
#
# Not auto-loaded by any script — export these into your shell, or use
# `set -a; source .env.wire; set +a` before running a driver script.

TDA_DATA_DIR=
TDA_RESULTS_DIR=
TDA_MODELS_DIR=
TDA_FIGURES_DIR=
